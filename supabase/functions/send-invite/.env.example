# Supabase Edge Function secrets
# Set these via: supabase secrets set KEY=value
# Or in the Supabase Dashboard → Edge Functions → Secrets

# Required — get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required — your Supabase project URL (auto-injected in production)
SUPABASE_URL=https://xrdbqgmmjunoyelrvxtu.supabase.co

# Required — anon key (auto-injected in production)
SUPABASE_ANON_KEY=your_anon_key_here

# Optional — public web URL for the join link in the email
APP_URL=https://doable.app
